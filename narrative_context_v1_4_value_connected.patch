+def _h2h_edge(h2h: Dict[str, Any]) -> str:
+    hw = int(h2h.get("home_wins") or 0)
+    aw = int(h2h.get("away_wins") or 0)
+    diff = hw - aw
+    if diff >= 3:
+        return "home_clear"
+    if diff >= 1:
+        return "home_slight"
+    if diff <= -3:
+        return "away_clear"
+    if diff <= -1:
+        return "away_slight"
+    return "balanced"
+
+
+def _join_pt(parts: Tuple[str, ...]) -> str:
+    clean = [p for p in parts if p]
+    if not clean:
+        return ""
+    if len(clean) == 1:
+        return clean[0]
+    return ", ".join(clean[:-1]) + " e " + clean[-1]
