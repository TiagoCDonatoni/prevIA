# IMPORTANTE:
# frontend/.env.production pode continuar versionado se tiver apenas VITE_* público.
# backend/cloudrun.env.yaml pode continuar versionado enquanto o Cloud Build depender dele.
# Não colocar secrets reais nesses arquivos versionados.

